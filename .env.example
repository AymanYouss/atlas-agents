# ─────────────────────────────────────────────────────────────────────────────
# Atlas configuration. Copy to `.env` and fill in the secrets.
# ─────────────────────────────────────────────────────────────────────────────

# --- Core ---
ATLAS_ENV=development
ATLAS_LOG_LEVEL=INFO
ATLAS_API_HOST=0.0.0.0
ATLAS_API_PORT=8000
# Comma-separated list of allowed CORS origins for the web UI.
ATLAS_CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# --- LLM providers ---
# Default provider: anthropic | openai
ATLAS_LLM_PROVIDER=anthropic

# Model role assignments. Planner/critic use a stronger model; executors a faster one.
ATLAS_PLANNER_MODEL=claude-opus-4-8
ATLAS_EXECUTOR_MODEL=claude-sonnet-4-6
ATLAS_CRITIC_MODEL=claude-opus-4-8

ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# --- Persistence ---
# Async SQLAlchemy URL for the app; LangGraph checkpointer derives a sync URL from it.
ATLAS_DATABASE_URL=postgresql+asyncpg://atlas:atlas@localhost:5432/atlas

# --- MCP tool servers ---
# Web search (Tavily is the reference provider; any MCP web-search server works).
TAVILY_API_KEY=tvly-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# --- Code sandbox ---
# Docker image used for sandboxed code execution.
ATLAS_SANDBOX_IMAGE=atlas-sandbox:latest
ATLAS_SANDBOX_CPU_LIMIT=1.0
ATLAS_SANDBOX_MEMORY_LIMIT=512m
ATLAS_SANDBOX_TIMEOUT_SECONDS=30
ATLAS_SANDBOX_NETWORK=none

# --- Guardrails ---
ATLAS_MAX_STEPS=24
ATLAS_MAX_RETRIES_PER_STEP=2
ATLAS_MAX_WALL_CLOCK_SECONDS=900
ATLAS_MAX_TOKENS_PER_RUN=2000000

# --- Observability ---
ATLAS_ENABLE_METRICS=true
