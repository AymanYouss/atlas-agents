# syntax=docker/dockerfile:1.7
# ─────────────────────────────────────────────────────────────────────────────
# Runtime image for the code-execution sandbox. Deliberately minimal: a small
# Python plus a curated scientific stack, a non-root user, and nothing else.
# The container is always launched with --network none, a read-only rootfs and a
# tmpfs /workspace by atlas.sandbox.docker_sandbox, so this image only needs the
# interpreter and safe libraries.
#   docker build -f deploy/docker/Dockerfile.sandbox -t atlas-sandbox:latest .
# ─────────────────────────────────────────────────────────────────────────────
FROM python:3.12-slim

ENV PYTHONUNBUFFERED=1 \
    PYTHONDONTWRITEBYTECODE=1 \
    PIP_NO_CACHE_DIR=1

# A small, useful, offline analysis stack. No network is available at run time.
RUN pip install --no-cache-dir \
        numpy==2.1.3 \
        pandas==2.2.3 \
        sympy==1.13.3 \
    && groupadd --system --gid 1000 sandbox \
    && useradd --system --uid 1000 --gid sandbox sandbox \
    && mkdir -p /workspace && chown sandbox:sandbox /workspace

WORKDIR /workspace
USER sandbox

# Default command is overridden per-run; this is a safe no-op fallback.
CMD ["python", "-c", "print('atlas-sandbox ready')"]
